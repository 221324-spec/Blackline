/* AI Analysis Page Styles */
.ai-analysis-page {
  width: 100%;
  height: 100%;
  padding: 0;
  animation: fadeIn 0.5s ease-in;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 400px;
  gap: 1rem;
}

.spinner {
  width: 50px;
  height: 50px;
  border: 4px solid #e2e8f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Page Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  gap: 1rem;
  flex-wrap: wrap;
}

.page-header h1 {
  font-size: 2rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 0.5rem 0;
}

.page-description {
  color: #64748b;
  font-size: 1rem;
  margin: 0;
}

.header-actions {
  display: flex;
  gap: 1rem;
}

.btn-bulk-analyze {
  padding: 0.75rem 1.5rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
}

.btn-bulk-analyze:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
}

.btn-bulk-analyze:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Error Banner */
.error-banner {
  background: linear-gradient(135deg, #f56565 0%, #c53030 100%);
  color: white;
  padding: 1rem 1.5rem;
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
  box-shadow: 0 4px 15px rgba(245, 101, 101, 0.3);
}

.error-icon {
  font-size: 1.5rem;
}

.error-banner button {
  margin-left: auto;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  color: white;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  cursor: pointer;
  transition: background 0.3s ease;
}

.error-banner button:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* Daily Advice Card */
.advice-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20px;
  padding: 2rem;
  color: white;
  margin-bottom: 2rem;
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.card-header h2 {
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0;
}

.timestamp {
  font-size: 0.875rem;
  opacity: 0.9;
}

.advice-content {
  display: grid;
  gap: 1.5rem;
}

.advice-text p {
  margin: 0.75rem 0;
  line-height: 1.6;
  font-size: 1.05rem;
}

.advice-metrics {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
  margin-top: 1rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.2);
}

.metric-item {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.metric-label {
  font-size: 0.875rem;
  opacity: 0.9;
}

.metric-value {
  font-size: 1.5rem;
  font-weight: 700;
}

/* Pattern Analysis Section */
.pattern-analysis-section {
  margin-bottom: 2rem;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.section-header h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0;
}

.btn-analyze-patterns {
  padding: 0.75rem 1.5rem;
  background: white;
  color: #667eea;
  border: 2px solid #667eea;
  border-radius: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-analyze-patterns:hover:not(:disabled) {
  background: #667eea;
  color: white;
  transform: translateY(-2px);
}

.btn-analyze-patterns:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-view-all {
  padding: 0.5rem 1rem;
  background: transparent;
  color: #667eea;
  text-decoration: none;
  font-weight: 600;
  border-radius: 8px;
  transition: all 0.3s ease;
}

.btn-view-all:hover {
  background: rgba(102, 126, 234, 0.1);
}

/* Pattern Insights Card */
.pattern-insights-card {
  background: white;
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.insights-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid #e2e8f0;
}

.stat-box {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1rem;
  background: #f8fafc;
  border-radius: 12px;
}

.stat-label {
  font-size: 0.875rem;
  color: #64748b;
  font-weight: 500;
}

.stat-value {
  font-size: 1.75rem;
  font-weight: 700;
  color: #1e293b;
}

.stat-value.success {
  color: #10b981;
}

.stat-value.danger {
  color: #ef4444;
}

.insights-content h3 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 1.5rem 0;
  padding-bottom: 1rem;
  border-bottom: 2px solid #e2e8f0;
}

.insights-sections {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.insight-section {
  background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 1.5rem;
  transition: all 0.3s ease;
}

.insight-section:hover {
  border-color: #3b82f6;
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
  transform: translateY(-2px);
}

.insight-section h4 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 1rem 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.section-content {
  line-height: 1.8;
  color: #475569;
}

.section-content p {
  margin: 0.5rem 0;
}

.section-content .bullet-point {
  padding-left: 1.5rem;
  position: relative;
  margin: 0.75rem 0;
}

.section-content .bullet-point::before {
  content: '•';
  position: absolute;
  left: 0.5rem;
  color: #3b82f6;
  font-weight: bold;
  font-size: 1.2rem;
}

.insights-text {
  line-height: 1.8;
  color: #475569;
}

.insights-text p {
  margin: 0.75rem 0;
  white-space: pre-wrap;
}

.insights-footer {
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid #e2e8f0;
}

.insights-footer .timestamp {
  color: #94a3b8;
  font-size: 0.875rem;
}

/* Empty State */
.empty-state {
  background: white;
  border-radius: 20px;
  padding: 3rem 2rem;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.empty-icon {
  font-size: 4rem;
  margin-bottom: 1rem;
}

.empty-state h3 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 0.5rem 0;
}

.empty-state p {
  color: #64748b;
  margin: 0.5rem 0;
}

.empty-note {
  font-size: 0.875rem;
  color: #94a3b8;
  font-style: italic;
}

/* Trades Analysis Section */
.trades-analysis-section {
  margin-bottom: 2rem;
}

.trades-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 1.5rem;
}

/* Trade Analysis Card */
.trade-analysis-card {
  background: white;
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.trade-analysis-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 25px rgba(0, 0, 0, 0.12);
}

.trade-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid #e2e8f0;
}

.trade-symbol {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.symbol {
  font-size: 1.25rem;
  font-weight: 700;
  color: #1e293b;
}

.result-badge {
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
}

.result-badge.win {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.result-badge.loss {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.result-badge.open {
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
}

.trade-profit {
  font-size: 1.25rem;
  font-weight: 700;
}

.trade-profit .positive {
  color: #10b981;
}

.trade-profit .negative {
  color: #ef4444;
}

/* Trade Details */
.trade-details {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  font-size: 0.875rem;
}

.detail-item .label {
  color: #64748b;
  font-weight: 500;
}

.detail-item .value {
  color: #1e293b;
  font-weight: 600;
}

/* AI Analysis Box */
.ai-analysis-box {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-left: 4px solid #667eea;
  border-radius: 12px;
  padding: 1rem;
  margin-bottom: 1rem;
}

.analysis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.75rem;
}

.ai-badge {
  font-size: 0.75rem;
  font-weight: 700;
  color: #667eea;
  background: white;
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
}

.analysis-time {
  font-size: 0.75rem;
  color: #64748b;
}

.analysis-text {
  color: #475569;
  line-height: 1.6;
  margin: 0;
  font-size: 0.925rem;
}

/* Trade Actions */
.trade-actions {
  display: flex;
  gap: 0.75rem;
}

.btn-action {
  flex: 1;
  padding: 0.625rem 1rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-action:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
}

.btn-action:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-action.secondary {
  background: white;
  color: #667eea;
  border: 2px solid #667eea;
}

.btn-action.secondary:hover:not(:disabled) {
  background: #f8fafc;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);
}

/* Setup Notice */
.setup-notice {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 16px;
  padding: 2rem;
  margin-top: 2rem;
}

.setup-notice h3 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #78350f;
  margin: 0 0 1rem 0;
}

.setup-notice ol {
  margin: 0;
  padding-left: 1.5rem;
  color: #92400e;
}

.setup-notice li {
  margin: 0.5rem 0;
  line-height: 1.6;
}

/* Responsive Design */
@media (max-width: 768px) {
  .page-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .header-actions {
    width: 100%;
  }

  .btn-bulk-analyze {
    width: 100%;
  }

  .trades-grid {
    grid-template-columns: 1fr;
  }

  .advice-metrics {
    grid-template-columns: 1fr;
  }

  .insights-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .page-header h1 {
    font-size: 1.5rem;
  }

  .trade-symbol {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .insights-stats {
    grid-template-columns: 1fr;
  }
}
